# ─── App ──────────────────────────────
NODE_ENV=development
APP_NAME=Wisender Pro
APP_PORT=4000
API_URL=http://localhost:4000/api
WEB_URL=http://localhost:3000

# ─── Database ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=wisender
DB_PASSWORD=wisender_secret_2026
DB_DATABASE=wisender_pro

# ─── Redis ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── MinIO (S3-compatible) ─────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=wisender
MINIO_SECRET_KEY=wisender_secret_2026
MINIO_BUCKET=wisender-media
MINIO_USE_SSL=false

# ─── WhatsApp ──────────────────────────
WHATSAPP_PROVIDER=baileys
WHATSAPP_WEBHOOK_URL=http://localhost:4000/api/whatsapp/webhook

# ─── AI ───────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_URL=http://localhost:11434
AI_PROVIDER=openai

# ─── BullMQ ────────────────────────────
BULLMQ_PREFIX=bull
BULLMQ_DEFAULT_JOBS=5

# ─── Conekta (México) ─────────────────
CONEKTA_PUBLIC_KEY=
CONEKTA_PRIVATE_KEY=
CONEKTA_WEBHOOK_SECRET=
